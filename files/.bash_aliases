# ~/.bash_aliases base for Naicibox

# Git
alias gs='git status'
alias ga='git add .'
alias gc='git commit -m'
alias gp='git push'
alias gl='git pull'

# Docker
alias dps='docker ps'
alias dcu='docker compose up'
alias dcd='docker compose down'
alias dcb='docker compose build'

# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias proj='cd $PROJECTS_HOME'
alias ll='ls -alF'